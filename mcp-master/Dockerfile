# Etapa de build
FROM node:20-alpine AS build
WORKDIR /app

COPY package.json tsconfig.json ./
RUN npm install

COPY src ./src
RUN npm run build

# Runtime
FROM node:20-alpine
WORKDIR /app

ENV NODE_ENV=production

# Copiamos node_modules y dist ya compilado
COPY --from=build /app/node_modules ./node_modules
COPY --from=build /app/src/resources ./dist/resources
COPY --from=build /app/dist ./dist


EXPOSE 3080

CMD ["node", "dist/index.js"]

